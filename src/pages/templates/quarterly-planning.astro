---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="90-Day Quarterly Planning Worksheet | Growth Map"
  description="Free quarterly planning template. Set your 90-day priorities, assign owners, track progress weekly, and stop planning in annual cycles that never work."
  canonicalPath="/templates/quarterly-planning"
>

  <style>
    @media print {
      nav, footer, .no-print, button, .cta-section {
        display: none !important;
      }
      body {
        background: white !important;
        font-size: 11pt;
      }
      main {
        padding: 0 !important;
      }
      section {
        padding: 0.5rem 0 !important;
        break-inside: avoid;
      }
      .worksheet-section {
        border: 1px solid #ccc !important;
        page-break-inside: avoid;
      }
      input, textarea, select {
        border: 1px solid #ccc !important;
        box-shadow: none !important;
        background: white !important;
      }
      .print-header {
        display: block !important;
      }
    }
    .print-header {
      display: none;
    }
  </style>

  <div class="min-h-screen bg-white">

    <!-- PRINT-ONLY HEADER -->
    <div class="print-header px-6 pt-6">
      <h1 class="text-2xl font-bold text-navy">90-Day Quarterly Planning Worksheet</h1>
      <p class="text-sm text-mid-gray">growthmap.consulting</p>
    </div>

    <!-- SEO INTRO -->
    <section class="px-6 py-20 md:py-28">
      <div class="mx-auto max-w-[680px] text-center">
        <p class="mb-4 text-sm font-semibold uppercase tracking-widest text-bright-blue">Free Template</p>
        <h1 class="text-3xl font-bold leading-tight text-navy sm:text-4xl md:text-[52px] md:leading-[1.1]">
          90-Day Quarterly Planning Worksheet
        </h1>
        <p class="mt-6 text-lg leading-relaxed text-mid-gray">
          Most annual plans fail by February. The companies that actually hit their goals plan in 90-day cycles instead. A quarterly planning template forces you to pick fewer priorities, assign real owners, and check in weekly -- so nothing drifts for months without anyone noticing.
        </p>
        <p class="mt-4 text-lg leading-relaxed text-mid-gray">
          This free 90-day planning worksheet is designed to be simple enough that you'll actually use it. Fill it out directly on this page, print it for your wall, or use it to run your next quarterly planning session. No email required, no gated PDF -- just a practical quarterly business goals template you can start using in the next ten minutes.
        </p>
        <p class="mt-4 text-lg leading-relaxed text-mid-gray">
          Whether you call them quarterly priorities, 90-day sprints, or just "the plan," the format matters less than the discipline. Pick your priorities, name who owns each one, define what done looks like, and review every week. That is the entire system.
        </p>
        <p class="mt-4 text-sm text-mid-gray">Fill it in below. No sign-up needed.</p>
      </div>
    </section>

    <!-- WORKSHEET -->
    <section class="px-6 pb-16">
      <div class="mx-auto max-w-[800px] space-y-10">

        <!-- Section 1: Current State -->
        <div class="worksheet-section rounded-xl border border-gray-200 p-6 md:p-8">
          <div class="mb-6">
            <span class="inline-block rounded-full bg-bright-blue/10 px-3 py-1 text-xs font-semibold uppercase tracking-widest text-bright-blue">Section 1</span>
            <h2 class="mt-3 text-xl font-bold text-navy md:text-2xl">Where Are We Now?</h2>
            <p class="mt-1 text-sm text-mid-gray">Honest snapshot of the current quarter before you plan the next one.</p>
          </div>

          <div class="space-y-5">
            <div>
              <label class="block text-sm font-semibold text-dark-text mb-1">Revenue this quarter</label>
              <div class="flex items-center gap-2">
                <span class="text-navy font-semibold">$</span>
                <input
                  type="text"
                  inputmode="numeric"
                  placeholder="e.g. 450,000"
                  class="w-full rounded-lg border border-gray-200 px-4 py-2.5 text-base text-dark-text placeholder:text-mid-gray focus:border-bright-blue focus:outline-none focus:ring-2 focus:ring-bright-blue/20"
                />
              </div>
            </div>

            <div>
              <label class="block text-sm font-semibold text-dark-text mb-1">Biggest win last quarter</label>
              <input
                type="text"
                placeholder="What went well that you want to build on?"
                class="w-full rounded-lg border border-gray-200 px-4 py-2.5 text-base text-dark-text placeholder:text-mid-gray focus:border-bright-blue focus:outline-none focus:ring-2 focus:ring-bright-blue/20"
              />
            </div>

            <div>
              <label class="block text-sm font-semibold text-dark-text mb-1">Biggest miss last quarter</label>
              <input
                type="text"
                placeholder="What fell short or didn't get done?"
                class="w-full rounded-lg border border-gray-200 px-4 py-2.5 text-base text-dark-text placeholder:text-mid-gray focus:border-bright-blue focus:outline-none focus:ring-2 focus:ring-bright-blue/20"
              />
            </div>

            <div>
              <label class="block text-sm font-semibold text-dark-text mb-1">What's working that we should keep doing</label>
              <textarea
                rows="3"
                placeholder="Processes, habits, team dynamics that are producing results..."
                class="w-full rounded-lg border border-gray-200 px-4 py-2.5 text-base text-dark-text placeholder:text-mid-gray focus:border-bright-blue focus:outline-none focus:ring-2 focus:ring-bright-blue/20 resize-y"
              ></textarea>
            </div>

            <div>
              <label class="block text-sm font-semibold text-dark-text mb-1">What's not working that we need to fix</label>
              <textarea
                rows="3"
                placeholder="Bottlenecks, broken processes, things draining energy..."
                class="w-full rounded-lg border border-gray-200 px-4 py-2.5 text-base text-dark-text placeholder:text-mid-gray focus:border-bright-blue focus:outline-none focus:ring-2 focus:ring-bright-blue/20 resize-y"
              ></textarea>
            </div>
          </div>
        </div>

        <!-- Section 2: 90-Day Targets -->
        <div class="worksheet-section rounded-xl border border-gray-200 p-6 md:p-8">
          <div class="mb-6">
            <span class="inline-block rounded-full bg-bright-blue/10 px-3 py-1 text-xs font-semibold uppercase tracking-widest text-bright-blue">Section 2</span>
            <h2 class="mt-3 text-xl font-bold text-navy md:text-2xl">Where Do We Want to Be?</h2>
            <p class="mt-1 text-sm text-mid-gray">Your 90-day targets. Fewer priorities = more progress.</p>
          </div>

          <div class="space-y-5">
            <div>
              <label class="block text-sm font-semibold text-dark-text mb-1">Revenue target for next quarter</label>
              <div class="flex items-center gap-2">
                <span class="text-navy font-semibold">$</span>
                <input
                  type="text"
                  inputmode="numeric"
                  placeholder="e.g. 525,000"
                  class="w-full rounded-lg border border-gray-200 px-4 py-2.5 text-base text-dark-text placeholder:text-mid-gray focus:border-bright-blue focus:outline-none focus:ring-2 focus:ring-bright-blue/20"
                />
              </div>
            </div>

            <div>
              <label class="block text-sm font-semibold text-dark-text mb-1">#1 company-wide goal this quarter</label>
              <input
                type="text"
                placeholder="If you could only accomplish one thing in 90 days, what would it be?"
                class="w-full rounded-lg border border-gray-200 px-4 py-2.5 text-base text-dark-text placeholder:text-mid-gray focus:border-bright-blue focus:outline-none focus:ring-2 focus:ring-bright-blue/20"
              />
            </div>

            <!-- Quarterly Priorities / Priorities -->
            <div>
              <label class="block text-sm font-semibold text-dark-text mb-2">Quarterly priorities</label>
              <p class="text-xs text-mid-gray mb-3">3-5 specific, measurable priorities with clear owners. If everything is a priority, nothing is.</p>

              <div id="priorities-list" class="space-y-4">
                <!-- Priorities inserted by JS -->
              </div>

              <button
                id="btn-add-priority"
                type="button"
                class="no-print mt-4 text-sm font-semibold text-bright-blue hover:text-navy transition-colors"
              >
                + Add another priority
              </button>
            </div>
          </div>
        </div>

        <!-- Section 3: Issues -->
        <div class="worksheet-section rounded-xl border border-gray-200 p-6 md:p-8">
          <div class="mb-6">
            <span class="inline-block rounded-full bg-bright-blue/10 px-3 py-1 text-xs font-semibold uppercase tracking-widest text-bright-blue">Section 3</span>
            <h2 class="mt-3 text-xl font-bold text-navy md:text-2xl">What Could Get in the Way?</h2>
            <p class="mt-1 text-sm text-mid-gray">Name the top issues or obstacles so they don't blindside you mid-quarter.</p>
          </div>

          <div class="space-y-4">
            <div>
              <label class="block text-sm font-semibold text-dark-text mb-1">Issue #1</label>
              <input
                type="text"
                placeholder="e.g. We don't have a strong enough pipeline to hit the revenue target"
                class="w-full rounded-lg border border-gray-200 px-4 py-2.5 text-base text-dark-text placeholder:text-mid-gray focus:border-bright-blue focus:outline-none focus:ring-2 focus:ring-bright-blue/20"
              />
            </div>
            <div>
              <label class="block text-sm font-semibold text-dark-text mb-1">Issue #2</label>
              <input
                type="text"
                placeholder="e.g. Key hire still unfilled, team is stretched thin"
                class="w-full rounded-lg border border-gray-200 px-4 py-2.5 text-base text-dark-text placeholder:text-mid-gray focus:border-bright-blue focus:outline-none focus:ring-2 focus:ring-bright-blue/20"
              />
            </div>
            <div>
              <label class="block text-sm font-semibold text-dark-text mb-1">Issue #3</label>
              <input
                type="text"
                placeholder="e.g. Onboarding process is broken, new clients churn in month 2"
                class="w-full rounded-lg border border-gray-200 px-4 py-2.5 text-base text-dark-text placeholder:text-mid-gray focus:border-bright-blue focus:outline-none focus:ring-2 focus:ring-bright-blue/20"
              />
            </div>
          </div>
        </div>

        <!-- Section 4: Weekly Check-In -->
        <div class="worksheet-section rounded-xl border border-gray-200 p-6 md:p-8">
          <div class="mb-6">
            <span class="inline-block rounded-full bg-bright-blue/10 px-3 py-1 text-xs font-semibold uppercase tracking-widest text-bright-blue">Section 4</span>
            <h2 class="mt-3 text-xl font-bold text-navy md:text-2xl">Weekly Check-In Plan</h2>
            <p class="mt-1 text-sm text-mid-gray">A plan without a weekly rhythm is just a wish. Lock in the cadence now.</p>
          </div>

          <div class="space-y-5">
            <div>
              <label class="block text-sm font-semibold text-dark-text mb-1">What day and time will you review progress?</label>
              <div class="flex flex-wrap gap-3">
                <select class="rounded-lg border border-gray-200 px-4 py-2.5 text-base text-dark-text focus:border-bright-blue focus:outline-none focus:ring-2 focus:ring-bright-blue/20">
                  <option value="" disabled selected>Day</option>
                  <option>Monday</option>
                  <option>Tuesday</option>
                  <option>Wednesday</option>
                  <option>Thursday</option>
                  <option>Friday</option>
                </select>
                <input
                  type="time"
                  value="09:00"
                  class="rounded-lg border border-gray-200 px-4 py-2.5 text-base text-dark-text focus:border-bright-blue focus:outline-none focus:ring-2 focus:ring-bright-blue/20"
                />
              </div>
            </div>

            <div>
              <label class="block text-sm font-semibold text-dark-text mb-1">Who's in the room?</label>
              <input
                type="text"
                placeholder="e.g. CEO, Head of Sales, Head of Ops, Head of Product"
                class="w-full rounded-lg border border-gray-200 px-4 py-2.5 text-base text-dark-text placeholder:text-mid-gray focus:border-bright-blue focus:outline-none focus:ring-2 focus:ring-bright-blue/20"
              />
            </div>

            <div>
              <label class="block text-sm font-semibold text-dark-text mb-2">What 3-5 numbers will you track weekly?</label>
              <p class="text-xs text-mid-gray mb-3">These are the leading indicators that tell you if you are on track before it is too late to course-correct.</p>

              <div id="metrics-list" class="space-y-3">
                <!-- Metrics inserted by JS -->
              </div>

              <button
                id="btn-add-metric"
                type="button"
                class="no-print mt-3 text-sm font-semibold text-bright-blue hover:text-navy transition-colors"
              >
                + Add another metric
              </button>
            </div>
          </div>
        </div>

        <!-- Print Button -->
        <div class="no-print flex justify-center">
          <button
            id="btn-print"
            class="rounded-lg bg-navy px-8 py-3.5 text-base font-semibold text-white transition-colors hover:bg-navy/90"
          >
            Print This Worksheet
          </button>
        </div>

      </div>
    </section>

    <!-- HOW TO USE -->
    <section class="bg-light-gray px-6 py-16 md:py-20 no-print">
      <div class="mx-auto max-w-[680px]">
        <h2 class="text-2xl font-bold text-navy md:text-3xl text-center">How to Use This Quarterly Planning Template</h2>
        <div class="mt-10 space-y-6">
          <div class="flex gap-4">
            <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-bright-blue text-sm font-bold text-white">1</span>
            <div>
              <h3 class="font-semibold text-navy">Review it every week</h3>
              <p class="mt-1 text-sm text-mid-gray leading-relaxed">Put your weekly check-in on the calendar the moment you finish this worksheet. The plan only works if you look at it. Every week, ask: are we on track, off track, or stuck? Then decide what to do about it before the next meeting.</p>
            </div>
          </div>
          <div class="flex gap-4">
            <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-bright-blue text-sm font-bold text-white">2</span>
            <div>
              <h3 class="font-semibold text-navy">Keep it visible</h3>
              <p class="mt-1 text-sm text-mid-gray leading-relaxed">Print it and put it on the wall. Share it in your team Slack channel. Make it the first slide in your weekly meeting. Quarterly plans fail when they get buried in a Google Drive folder and forgotten by week three.</p>
            </div>
          </div>
          <div class="flex gap-4">
            <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-bright-blue text-sm font-bold text-white">3</span>
            <div>
              <h3 class="font-semibold text-navy">Update priorities at the 30-day mark</h3>
              <p class="mt-1 text-sm text-mid-gray leading-relaxed">At the one-month mark, do a gut check. Are your priorities still right? Has something changed? It is fine to adjust scope or swap a priority -- what matters is that you are being intentional about it rather than just letting things drift.</p>
            </div>
          </div>
          <div class="flex gap-4">
            <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-bright-blue text-sm font-bold text-white">4</span>
            <div>
              <h3 class="font-semibold text-navy">Celebrate wins</h3>
              <p class="mt-1 text-sm text-mid-gray leading-relaxed">When you complete a priority, acknowledge it. Teams that only focus on what is left to do burn out. Take five minutes in your weekly meeting to call out progress -- it compounds morale and momentum faster than you would expect.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="cta-section px-6 py-16 md:py-20 no-print">
      <div class="mx-auto max-w-[680px]">
        <div class="rounded-xl bg-navy p-8 md:p-12 text-center">
          <h2 class="text-2xl font-bold text-white md:text-3xl">Want help building a quarterly plan that your team actually executes?</h2>
          <p class="mt-4 text-white/70 leading-relaxed">Most teams know what to do. The hard part is building the system that makes sure it actually happens -- the right meeting rhythms, the right accountability, the right metrics. That is what a fractional COO does.</p>
          <div class="mt-8 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
            <a
              href="https://calendar.notion.so/meet/cameronearloliver/qc3y04oud"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-block rounded-lg bg-bright-blue px-8 py-3.5 text-base font-semibold text-white transition-colors hover:bg-[#0088c2]"
            >
              Book a Free Consult
            </a>
            <a
              href="/time-audit"
              class="inline-block rounded-lg border border-white/30 px-8 py-3.5 text-base font-semibold text-white transition-colors hover:border-white/60"
            >
              Take the Time Audit
            </a>
          </div>
        </div>
      </div>
    </section>

  </div>

  <script>
    // --- Priorities (Quarterly Priorities) ---
    let priorityCount = 0;

    function createPriorityItem(index) {
      const div = document.createElement('div');
      div.className = 'priority-item rounded-lg border border-gray-200 bg-light-gray/50 p-4';
      div.dataset.index = index;

      div.innerHTML = `
        <div class="flex items-center justify-between mb-3">
          <span class="text-sm font-bold text-navy">Priority #${index}</span>
          <button type="button" class="btn-remove-priority no-print text-xs text-mid-gray hover:text-red-500 transition-colors">Remove</button>
        </div>
        <div class="grid gap-3 sm:grid-cols-2">
          <div class="sm:col-span-2">
            <label class="block text-xs font-semibold text-mid-gray mb-1">Priority name</label>
            <input
              type="text"
              placeholder="e.g. Launch self-serve onboarding flow"
              class="w-full rounded-lg border border-gray-200 px-3 py-2 text-sm text-dark-text placeholder:text-mid-gray focus:border-bright-blue focus:outline-none focus:ring-2 focus:ring-bright-blue/20"
            />
          </div>
          <div>
            <label class="block text-xs font-semibold text-mid-gray mb-1">Owner</label>
            <input
              type="text"
              placeholder="Who is accountable?"
              class="w-full rounded-lg border border-gray-200 px-3 py-2 text-sm text-dark-text placeholder:text-mid-gray focus:border-bright-blue focus:outline-none focus:ring-2 focus:ring-bright-blue/20"
            />
          </div>
          <div>
            <label class="block text-xs font-semibold text-mid-gray mb-1">Due date</label>
            <input
              type="date"
              class="w-full rounded-lg border border-gray-200 px-3 py-2 text-sm text-dark-text focus:border-bright-blue focus:outline-none focus:ring-2 focus:ring-bright-blue/20"
            />
          </div>
          <div class="sm:col-span-2">
            <label class="block text-xs font-semibold text-mid-gray mb-1">Success metric</label>
            <input
              type="text"
              placeholder="How will you know it's done? Be specific."
              class="w-full rounded-lg border border-gray-200 px-3 py-2 text-sm text-dark-text placeholder:text-mid-gray focus:border-bright-blue focus:outline-none focus:ring-2 focus:ring-bright-blue/20"
            />
          </div>
        </div>
      `;

      // Remove handler
      div.querySelector('.btn-remove-priority').addEventListener('click', () => {
        div.remove();
        renumberPriorities();
      });

      return div;
    }

    function renumberPriorities() {
      const items = document.querySelectorAll('#priorities-list .priority-item');
      items.forEach((item, i) => {
        item.querySelector('.text-navy').textContent = `Priority #${i + 1}`;
        item.dataset.index = i + 1;
      });
      priorityCount = items.length;
    }

    function addPriority() {
      priorityCount++;
      const list = document.getElementById('priorities-list');
      list.appendChild(createPriorityItem(priorityCount));
    }

    // Init 3 priorities
    addPriority();
    addPriority();
    addPriority();

    document.getElementById('btn-add-priority').addEventListener('click', () => {
      if (priorityCount >= 7) return; // soft cap to keep focus
      addPriority();
    });

    // --- Weekly Metrics ---
    let metricCount = 0;

    function createMetricItem(index) {
      const div = document.createElement('div');
      div.className = 'metric-item flex items-center gap-2';
      div.dataset.index = index;

      div.innerHTML = `
        <span class="shrink-0 text-xs font-bold text-mid-gray w-5">${index}.</span>
        <input
          type="text"
          placeholder="e.g. New leads generated, Revenue collected, NPS score..."
          class="w-full rounded-lg border border-gray-200 px-3 py-2 text-sm text-dark-text placeholder:text-mid-gray focus:border-bright-blue focus:outline-none focus:ring-2 focus:ring-bright-blue/20"
        />
        <button type="button" class="btn-remove-metric no-print shrink-0 text-xs text-mid-gray hover:text-red-500 transition-colors">Remove</button>
      `;

      div.querySelector('.btn-remove-metric').addEventListener('click', () => {
        div.remove();
        renumberMetrics();
      });

      return div;
    }

    function renumberMetrics() {
      const items = document.querySelectorAll('#metrics-list .metric-item');
      items.forEach((item, i) => {
        item.querySelector('.text-mid-gray.w-5').textContent = `${i + 1}.`;
        item.dataset.index = i + 1;
      });
      metricCount = items.length;
    }

    function addMetric() {
      metricCount++;
      const list = document.getElementById('metrics-list');
      list.appendChild(createMetricItem(metricCount));
    }

    // Init 3 metrics
    addMetric();
    addMetric();
    addMetric();

    document.getElementById('btn-add-metric').addEventListener('click', () => {
      if (metricCount >= 7) return;
      addMetric();
    });

    // --- Print ---
    document.getElementById('btn-print').addEventListener('click', () => {
      window.print();
    });
  </script>

</Layout>
