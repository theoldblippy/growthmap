---
const year = new Date().getFullYear();
---

<!-- Final CTA gradient banner -->
<section class="bg-gradient-to-r from-deep-accent to-bright-blue px-6 py-20 text-center text-white">
  <div class="mx-auto max-w-[800px]">
    <h2 class="text-3xl font-bold leading-tight md:text-4xl">
      Running your business shouldn't feel like guesswork. Book your free Growth Map Diagnostic.
    </h2>
    <a
      href="https://calendar.notion.so/meet/cameronearloliver/qc3y04oud"
      target="_blank"
      rel="noopener noreferrer"
      class="mt-8 inline-block rounded-lg bg-white px-8 py-3.5 text-base font-semibold text-deep-accent transition-colors hover:bg-light-gray"
    >
      Book a Free Consult
    </a>
  </div>
</section>

<footer class="bg-navy px-6 py-12 text-white">
  <div class="mx-auto flex max-w-[1200px] flex-col items-center gap-6 md:flex-row md:justify-between">
    <a href="/">
      <div class="inline-block rounded bg-white p-1.5">
        <img src="/images/logo.png" alt="Growth Map" class="h-8" />
      </div>
    </a>

    <nav class="flex gap-6">
      <a href="/" class="text-sm text-white/80 transition-colors hover:text-white">Home</a>
      <a href="/about" class="text-sm text-white/80 transition-colors hover:text-white">About</a>
      <a href="/blog" class="text-sm text-white/80 transition-colors hover:text-white">Blog</a>
      <a href="/contact" class="text-sm text-white/80 transition-colors hover:text-white">Contact</a>
    </nav>

    <div class="flex items-center gap-4">
      <a
        href="https://www.linkedin.com/in/cameronearloliver/"
        target="_blank"
        rel="noopener noreferrer"
        class="text-white/60 transition-colors hover:text-white"
        aria-label="LinkedIn"
      >
        <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
      </a>
      <p class="text-sm text-white/60">
        &copy; {year} Growth Map. All rights reserved.
      </p>
    </div>
  </div>
</footer>
