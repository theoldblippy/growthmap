---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Accountability Chart Template | Growth Map"
  description="Free accountability chart template. Define roles, assign ownership, and clarify who's accountable for what — so your team stops coming to you for every decision."
  canonicalPath="/templates/accountability-chart"
>
  <style>
    @media print {
      nav, footer, #intro-section, #how-to-section, #cta-section, #print-bar, .no-print {
        display: none !important;
      }
      body {
        background: white !important;
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
      }
      .role-card {
        break-inside: avoid;
        border-left: 4px solid #009CDE !important;
        margin-bottom: 12px !important;
        box-shadow: none !important;
        border: 1px solid #e5e7eb !important;
        border-left: 4px solid #009CDE !important;
      }
      #chart-section {
        padding: 0 !important;
      }
      .role-card input,
      .role-card select {
        border: none !important;
        padding: 0 !important;
        font-size: 13px !important;
        box-shadow: none !important;
        outline: none !important;
        background: transparent !important;
      }
      .role-card button {
        display: none !important;
      }
      #btn-add-role {
        display: none !important;
      }
      .print-title {
        display: block !important;
        font-size: 24px;
        font-weight: 700;
        margin-bottom: 16px;
      }
    }
    .print-title {
      display: none;
    }
  </style>

  <div class="min-h-screen bg-white">

    <!-- INTRO -->
    <section id="intro-section" class="px-6 py-20 md:py-28">
      <div class="mx-auto max-w-[680px] text-center">
        <p class="mb-4 text-sm font-semibold uppercase tracking-widest text-bright-blue">Free Template</p>
        <h1 class="text-3xl font-bold leading-tight text-navy sm:text-4xl md:text-[52px] md:leading-[1.1]">
          Accountability Chart Template
        </h1>
        <p class="mt-6 text-lg leading-relaxed text-mid-gray">
          Most org charts show who reports to whom. That's useful for HR, but it doesn't help you run the business. An accountability chart flips the model: instead of mapping reporting lines, it maps <strong class="text-dark-text">who owns what outcomes</strong>. Every seat on the chart has 3-5 measurable accountabilities attached to it, so there's zero ambiguity about who's responsible for what.
        </p>
        <p class="mt-4 text-lg leading-relaxed text-mid-gray">
          Traditional org charts answer "who does this person report to?" Accountability charts answer a much more useful question: "if this thing falls apart, whose seat is it?" When every function in your business has a clear owner with defined accountabilities, decisions get made faster, balls stop getting dropped, and you stop being the bottleneck.
        </p>
        <p class="mt-4 text-lg leading-relaxed text-mid-gray">
          Use the interactive builder below to map out your team's accountability chart. No sign-up, no email gate, no PDF download wall. Just fill it in and print it.
        </p>
      </div>
    </section>

    <!-- CHART BUILDER -->
    <section id="chart-section" class="px-6 pb-16 md:pb-24">
      <div class="mx-auto max-w-[900px]">

        <p class="print-title text-navy">Accountability Chart</p>

        <div class="mb-8 text-center no-print">
          <h2 class="text-2xl font-bold text-navy md:text-3xl">Build Your Accountability Chart</h2>
          <p class="mt-3 text-mid-gray">Start with leadership, then add every functional role your business needs.</p>
        </div>

        <!-- Role cards container -->
        <div id="roles-container" class="space-y-6"></div>

        <!-- Add role button -->
        <div class="mt-8 text-center">
          <button
            id="btn-add-role"
            class="inline-flex items-center gap-2 rounded-lg bg-bright-blue px-8 py-3.5 text-base font-semibold text-white transition-colors hover:bg-[#0088c2]"
          >
            <span class="text-xl leading-none">+</span> Add a Role
          </button>
        </div>

        <!-- Print bar -->
        <div id="print-bar" class="mt-10 flex justify-center">
          <button
            id="btn-print"
            class="inline-flex items-center gap-2 rounded-lg border-2 border-navy px-8 py-3.5 text-base font-semibold text-navy transition-colors hover:bg-navy hover:text-white"
          >
            <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"/></svg>
            Print Chart
          </button>
        </div>

      </div>
    </section>

    <!-- HOW TO BUILD -->
    <section id="how-to-section" class="bg-light-gray px-6 py-16 md:py-24">
      <div class="mx-auto max-w-[680px]">
        <p class="text-sm font-semibold uppercase tracking-widest text-bright-blue">Guide</p>
        <h2 class="mt-4 text-2xl font-bold text-navy md:text-3xl">How to Build Your Accountability Chart</h2>

        <div class="mt-10 space-y-8">
          <div>
            <h3 class="text-lg font-bold text-navy">1. Start with functions, not people</h3>
            <p class="mt-2 leading-relaxed text-mid-gray">
              Ask "what roles does this business need to run well?" before you ask "who do we have?" Design the chart for the business you're building, then map your current people into it. You'll quickly see gaps, overlaps, and seats that nobody actually owns.
            </p>
          </div>
          <div>
            <h3 class="text-lg font-bold text-navy">2. One person can sit in multiple seats</h3>
            <p class="mt-2 leading-relaxed text-mid-gray">
              In a small team, the founder might hold the Visionary seat, the Sales seat, and the Marketing seat. That's fine — the chart makes it explicit instead of assumed. As you grow, you'll hire into those seats one at a time.
            </p>
          </div>
          <div>
            <h3 class="text-lg font-bold text-navy">3. Every seat needs 3-5 measurable accountabilities</h3>
            <p class="mt-2 leading-relaxed text-mid-gray">
              If you can't write down what success looks like for a role, the role isn't defined well enough yet. Accountabilities should be specific and measurable: "Revenue hits $2M ARR" beats "Grow revenue." Think outcomes, not activities.
            </p>
          </div>
          <div>
            <h3 class="text-lg font-bold text-navy">4. If you can't define the accountabilities, the role isn't clear yet</h3>
            <p class="mt-2 leading-relaxed text-mid-gray">
              This is the whole point of the exercise. Fuzzy roles create confusion, dropped balls, and people stepping on each other's toes. If you're struggling to write clear accountabilities for a seat, that's the most valuable signal this chart can give you.
            </p>
          </div>
          <div>
            <h3 class="text-lg font-bold text-navy">5. Review quarterly — roles change as you grow</h3>
            <p class="mt-2 leading-relaxed text-mid-gray">
              Your accountability chart at 10 people will look nothing like your chart at 50. Revisit it every quarter: are the right people in the right seats? Have new functions emerged? Are accountabilities still accurate? A stale chart is worse than no chart.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section id="cta-section" class="px-6 py-16 md:py-24">
      <div class="mx-auto max-w-[680px]">
        <div class="rounded-xl bg-navy p-8 text-center md:p-12">
          <h2 class="text-2xl font-bold text-white md:text-3xl">Want help designing a team structure that actually scales?</h2>
          <p class="mt-4 text-white/70">
            An accountability chart is the starting point. Getting the right people in the right seats — and building the systems so they can actually own their outcomes — is where the real work begins.
          </p>
          <a
            href="https://calendar.notion.so/meet/cameronearloliver/qc3y04oud"
            target="_blank"
            rel="noopener noreferrer"
            class="mt-8 inline-block rounded-lg bg-bright-blue px-10 py-4 text-base font-semibold text-white transition-colors hover:bg-[#0088c2]"
          >
            Book a Free Consult
          </a>
          <p class="mt-4 text-sm text-white/50">
            Or try the <a href="/time-audit" class="underline text-white/70 hover:text-white transition-colors">CEO Time Audit</a> to see where your hours are actually going.
          </p>
        </div>
      </div>
    </section>

  </div>

  <script>
    let roleCounter = 0;

    function createRoleCard(options = {}) {
      const {
        isLeadership = false,
        defaultTitle = '',
        defaultName = '',
      } = options;

      const roleId = roleCounter++;
      const card = document.createElement('div');
      card.className = 'role-card rounded-xl border border-gray-100 bg-white p-6 shadow-sm';
      card.style.borderLeft = '4px solid #009CDE';
      card.dataset.roleId = roleId;

      // Header row
      const header = document.createElement('div');
      header.className = 'flex items-start justify-between gap-4';

      const headerLeft = document.createElement('div');
      headerLeft.className = 'flex-1';

      if (isLeadership) {
        const badge = document.createElement('span');
        badge.className = 'mb-3 inline-block rounded-full bg-bright-blue/10 px-3 py-1 text-xs font-semibold text-bright-blue';
        badge.textContent = 'Leadership';
        headerLeft.appendChild(badge);
      }

      // Role title
      const titleLabel = document.createElement('label');
      titleLabel.className = 'block text-xs font-semibold uppercase tracking-wider text-mid-gray mb-1';
      titleLabel.textContent = 'Role Title';
      headerLeft.appendChild(titleLabel);

      const titleInput = document.createElement('input');
      titleInput.type = 'text';
      titleInput.placeholder = isLeadership ? 'e.g. Visionary / CEO' : 'e.g. Head of Sales';
      titleInput.value = defaultTitle;
      titleInput.className = 'role-title w-full rounded-lg border border-gray-200 px-4 py-2.5 text-base font-semibold text-dark-text placeholder:text-mid-gray/50 focus:border-bright-blue focus:outline-none focus:ring-2 focus:ring-bright-blue/20';
      titleInput.addEventListener('input', updateReportsToDropdowns);
      headerLeft.appendChild(titleInput);

      header.appendChild(headerLeft);

      // Remove button (not for leadership)
      if (!isLeadership) {
        const removeBtn = document.createElement('button');
        removeBtn.className = 'no-print mt-6 rounded-lg px-3 py-2 text-sm font-medium text-mid-gray transition-colors hover:bg-red-50 hover:text-red-500';
        removeBtn.textContent = 'Remove';
        removeBtn.addEventListener('click', () => {
          card.remove();
          updateReportsToDropdowns();
        });
        header.appendChild(removeBtn);
      }

      card.appendChild(header);

      // Person name + Reports to row
      const infoRow = document.createElement('div');
      infoRow.className = 'mt-4 grid gap-4 sm:grid-cols-2';

      // Person name
      const nameWrap = document.createElement('div');
      const nameLabel = document.createElement('label');
      nameLabel.className = 'block text-xs font-semibold uppercase tracking-wider text-mid-gray mb-1';
      nameLabel.textContent = "Person's Name";
      nameWrap.appendChild(nameLabel);

      const nameInput = document.createElement('input');
      nameInput.type = 'text';
      nameInput.placeholder = 'Who sits in this seat?';
      nameInput.value = defaultName;
      nameInput.className = 'role-person w-full rounded-lg border border-gray-200 px-4 py-2.5 text-base text-dark-text placeholder:text-mid-gray/50 focus:border-bright-blue focus:outline-none focus:ring-2 focus:ring-bright-blue/20';
      nameWrap.appendChild(nameInput);
      infoRow.appendChild(nameWrap);

      // Reports to
      if (!isLeadership) {
        const reportsWrap = document.createElement('div');
        const reportsLabel = document.createElement('label');
        reportsLabel.className = 'block text-xs font-semibold uppercase tracking-wider text-mid-gray mb-1';
        reportsLabel.textContent = 'Reports To';
        reportsWrap.appendChild(reportsLabel);

        const reportsSelect = document.createElement('select');
        reportsSelect.className = 'reports-to w-full rounded-lg border border-gray-200 px-4 py-2.5 text-base text-dark-text focus:border-bright-blue focus:outline-none focus:ring-2 focus:ring-bright-blue/20';
        reportsWrap.appendChild(reportsSelect);
        infoRow.appendChild(reportsWrap);
      }

      card.appendChild(infoRow);

      // Accountabilities
      const accSection = document.createElement('div');
      accSection.className = 'mt-5';

      const accLabel = document.createElement('label');
      accLabel.className = 'block text-xs font-semibold uppercase tracking-wider text-mid-gray mb-2';
      accLabel.textContent = 'Key Accountabilities';
      accSection.appendChild(accLabel);

      const accList = document.createElement('div');
      accList.className = 'acc-list space-y-2';
      accSection.appendChild(accList);

      // Start with 3 accountability inputs
      for (let i = 0; i < 3; i++) {
        accList.appendChild(createAccInput(i + 1));
      }

      // Add accountability button
      const addAccBtn = document.createElement('button');
      addAccBtn.className = 'no-print mt-2 text-sm font-semibold text-bright-blue transition-colors hover:text-navy';
      addAccBtn.textContent = '+ Add accountability';
      addAccBtn.addEventListener('click', () => {
        const count = accList.querySelectorAll('.acc-row').length;
        if (count < 7) {
          accList.appendChild(createAccInput(count + 1));
        }
      });
      accSection.appendChild(addAccBtn);

      card.appendChild(accSection);

      return card;
    }

    function createAccInput(num) {
      const row = document.createElement('div');
      row.className = 'acc-row flex items-center gap-2';

      const dot = document.createElement('span');
      dot.className = 'h-1.5 w-1.5 flex-shrink-0 rounded-full bg-bright-blue';
      row.appendChild(dot);

      const input = document.createElement('input');
      input.type = 'text';
      input.placeholder = `Accountability #${num} (e.g. "Revenue hits $2M ARR")`;
      input.className = 'acc-input flex-1 rounded-lg border border-gray-200 px-3 py-2 text-sm text-dark-text placeholder:text-mid-gray/50 focus:border-bright-blue focus:outline-none focus:ring-2 focus:ring-bright-blue/20';
      row.appendChild(input);

      const removeBtn = document.createElement('button');
      removeBtn.className = 'no-print flex-shrink-0 rounded p-1 text-mid-gray/40 transition-colors hover:text-red-500';
      removeBtn.innerHTML = '<svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>';
      removeBtn.addEventListener('click', () => {
        const list = row.closest('.acc-list');
        if (list && list.querySelectorAll('.acc-row').length > 1) {
          row.remove();
        }
      });
      row.appendChild(removeBtn);

      return row;
    }

    function updateReportsToDropdowns() {
      const allCards = document.querySelectorAll('.role-card');
      const roles = [];

      allCards.forEach(card => {
        const titleInput = card.querySelector('.role-title');
        const personInput = card.querySelector('.role-person');
        const roleId = card.dataset.roleId;
        const title = titleInput.value.trim() || 'Untitled Role';
        const person = personInput.value.trim();
        const label = person ? `${title} (${person})` : title;
        roles.push({ roleId, label });
      });

      allCards.forEach(card => {
        const select = card.querySelector('.reports-to');
        if (!select) return;

        const currentValue = select.value;
        select.innerHTML = '';

        const emptyOpt = document.createElement('option');
        emptyOpt.value = '';
        emptyOpt.textContent = '-- Select --';
        select.appendChild(emptyOpt);

        roles.forEach(role => {
          if (role.roleId === card.dataset.roleId) return;
          const opt = document.createElement('option');
          opt.value = role.roleId;
          opt.textContent = role.label;
          if (role.roleId === currentValue) opt.selected = true;
          select.appendChild(opt);
        });
      });
    }

    // Init
    function init() {
      const container = document.getElementById('roles-container');
      container.innerHTML = '';
      roleCounter = 0;

      // Leadership card
      container.appendChild(createRoleCard({
        isLeadership: true,
        defaultTitle: '',
        defaultName: '',
      }));

      updateReportsToDropdowns();
    }

    // Add role
    document.getElementById('btn-add-role').addEventListener('click', () => {
      const container = document.getElementById('roles-container');
      container.appendChild(createRoleCard());
      updateReportsToDropdowns();

      // Scroll to the new card
      const cards = container.querySelectorAll('.role-card');
      const lastCard = cards[cards.length - 1];
      lastCard.scrollIntoView({ behavior: 'smooth', block: 'center' });
      lastCard.querySelector('.role-title').focus();
    });

    // Print
    document.getElementById('btn-print').addEventListener('click', () => {
      window.print();
    });

    init();
  </script>
</Layout>
