---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout
  title="Blog | Growth Map - Fractional COO & Business Operations Insights"
  description="Practical insights on fractional COO leadership, business operations, and growth strategy for founders scaling from $1M to $10M."
  canonicalPath="/blog"
>
  <section class="bg-white px-6 py-20 md:py-28">
    <div class="mx-auto max-w-[800px]">
      <p class="mb-4 text-sm font-semibold uppercase tracking-widest text-bright-blue">
        Insights
      </p>
      <h1 class="text-3xl font-bold leading-tight text-navy sm:text-4xl md:text-[48px] md:leading-[1.1]">
        Blog
      </h1>
      <p class="mt-4 text-lg text-mid-gray">
        Practical thinking on growth, operations, and building a business that runs without you.
      </p>
    </div>
  </section>

  <section class="bg-light-gray px-6 py-16 md:py-20">
    <div class="mx-auto max-w-[800px] space-y-8">
      {posts.length === 0 && (
        <p class="text-center text-mid-gray">No posts yet. Check back soon.</p>
      )}
      {posts.map((post) => (
        <a
          href={`/blog/${post.id}`}
          class="block rounded-xl bg-white p-8 transition-shadow hover:shadow-md"
        >
          <time class="text-sm text-mid-gray">
            {post.data.date.toLocaleDateString('en-US', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            })}
          </time>
          <h2 class="mt-2 text-xl font-bold text-navy">{post.data.title}</h2>
          <p class="mt-2 leading-relaxed text-dark-text">{post.data.description}</p>
          <span class="mt-4 inline-block text-sm font-semibold text-bright-blue">
            Read more &rarr;
          </span>
        </a>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-white px-6 py-16">
    <div class="mx-auto max-w-[600px] text-center">
      <h2 class="text-xl font-bold text-navy">Want to See Where Your Business Stands?</h2>
      <p class="mt-3 text-mid-gray">Our free tools give you a clear picture in under 3 minutes.</p>
      <div class="mt-6 flex flex-wrap justify-center gap-4">
        <a
          href="/time-audit"
          class="inline-block rounded-lg bg-bright-blue px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-[#0088c2]"
        >
          Take the CEO Time Audit
        </a>
        <a
          href="/scale-readiness-score"
          class="inline-block rounded-lg border-2 border-navy px-6 py-3 text-sm font-semibold text-navy transition-colors hover:bg-navy hover:text-white"
        >
          Scale Readiness Score
        </a>
      </div>
    </div>
  </section>
</Layout>
